{
  "manifest_version": 3,
  "name": "BOSS 求职助手",
  "version": "0.1.0",
  "description": "采集 BOSS 岗位，并在审批后安全发送打招呼消息。",
  "permissions": ["activeTab", "tabs", "scripting", "storage"],
  "host_permissions": ["https://*.zhipin.com/*", "http://localhost:3000/*"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "BOSS 求职助手"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://*.zhipin.com/*"],
      "js": ["job-extractor.cjs", "boss-page-adapter.cjs", "content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["http://localhost:3000/*"],
      "js": ["workbench-bridge.js"],
      "run_at": "document_start"
    }
  ]
}
