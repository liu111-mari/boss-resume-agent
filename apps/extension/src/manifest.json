{
  "manifest_version": 3,
  "name": "BOSS 求职助手",
  "version": "0.1.0",
  "description": "采集 BOSS 岗位和消息线索，并在审批后发送打招呼消息。",
  "permissions": ["activeTab", "tabs", "scripting"],
  "host_permissions": ["https://*.zhipin.com/*", "http://localhost:3000/*"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "BOSS 求职助手"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://*.zhipin.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
